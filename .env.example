# ======================
# Agent Studio Environment Variables
# ======================

# Node Environment
NODE_ENV=production

# ======================
# Xians API Configuration
# ======================
XIANS_APIKEY=your-xians-api-key-here
XIANS_SERVER_URL=https://your-xians-server.com

# ======================
# NextAuth Configuration
# ======================
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=your-nextauth-secret-here

# ======================
# Google OAuth Configuration
# ======================
# Get these from: https://console.cloud.google.com/apis/credentials
# Leave these empty/uncommented to disable Google SSO
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ======================
# Microsoft/Azure AD OAuth Configuration
# ======================
# Leave these empty/uncommented to disable Microsoft SSO
AZURE_AD_CLIENT_ID=your-azure-client-id
AZURE_AD_CLIENT_SECRET=your-azure-client-secret
AZURE_AD_TENANT_ID=your-azure-tenant-id
# Space-separated scopes. Must include offline_access (for refresh tokens) and
# your backend resource scope so the access_token is audienced for that API
# (not Microsoft Graph). Example:
# AZURE_AD_SCOPES=openid profile email offline_access api://your-app-id/access_as_user
# AZURE_AD_SCOPES=openid profile email offline_access

# ======================
# Azure AD B2C (custom-domain authority) Configuration
# ======================
# Use this for branded B2C login (e.g. HappyInc login-dev.happyinc.no).
# Redirect URI to register (Web platform): {NEXTAUTH_URL}/api/auth/callback/azure-ad-b2c
# Authority format: https://{customDomain}/{tenantOrCustomDomain}/{policy}
# Leave AZURE_AD_B2C_CLIENT_ID and/or AZURE_AD_B2C_AUTHORITY empty to disable.
# AZURE_AD_B2C_CLIENT_ID=your-b2c-application-client-id
# AZURE_AD_B2C_CLIENT_SECRET=your-b2c-client-secret
# AZURE_AD_B2C_AUTHORITY=https://login-dev.happyinc.no/login-dev.happyinc.no/B2C_1A_SIGNUP_SIGNIN_AI
# Scopes for B2C sign-in + API resource. Accepts space- or comma-separated.
# AZURE_AD_B2B_SCOPES takes precedence over AZURE_AD_B2C_SCOPES (Parkly style).
# AZURE_AD_B2B_SCOPES=openid, profile, offline_access, https://your-b2c-tenant.onmicrosoft.com/your-api/read
# AZURE_AD_B2C_SCOPES=openid profile email offline_access
# AZURE_AD_B2C_DISPLAY_NAME=HappyInc

# ======================
# Keycloak OIDC Configuration
# ======================
# Create a confidential client in Keycloak with "confidential" Access Type.
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/keycloak
# Issuer must include realm, e.g. https://keycloak.example.com/realms/My_Realm
# Leave these empty/uncommented to disable Keycloak SSO
KEYCLOAK_CLIENT_ID=your-keycloak-client-id
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret
KEYCLOAK_ISSUER=https://your-keycloak-domain.com/realms/Your_Realm

# ======================
# Visma Connect OIDC Configuration
# ======================
# Register an application at Visma Connect (https://oauth.developers.visma.com).
# Redirect URI to register: {NEXTAUTH_URL}/api/auth/callback/visma-connect
# Issuer (authority):
#   Staging:    https://connect.identity.stagaws.visma.com
#   Production: https://connect.visma.com
# Leave VISMA_CONNECT_CLIENT_ID and/or VISMA_CONNECT_ISSUER empty to disable Visma Connect SSO.
VISMA_CONNECT_CLIENT_ID=your-visma-connect-client-id
VISMA_CONNECT_ISSUER=https://connect.identity.stagaws.visma.com

# ======================
# Local Development Login (NEVER enable in production)
# ======================
# Provides a simple email/password login for quick local deployments.
# Set LOCAL_AUTH_ENABLED=true and provide comma-separated email:password pairs.
# Each email must be a Xians participant with tenant access.
# LOCAL_AUTH_ENABLED=true
# LOCAL_AUTH_USERS=admin@example.com:change-me,dev@example.com:change-me-too

# ======================
# Application Configuration
# ======================
# Port for the application (default: 3000)
PORT=3000

# Hostname to bind to (default: 0.0.0.0 for Docker)
HOSTNAME=0.0.0.0